# ─── Backend ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_random_string_here
JWT_REFRESH_SECRET=change_me_different_32_chars_random_string

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
