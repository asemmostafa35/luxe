{
  "name": "luxe-fashion-backend",
  "version": "1.0.0",
  "description": "Luxe Fashion E-Commerce Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:studio": "prisma studio",
    "db:sync-rbac": "prisma db execute --file scripts/sync-rbac-schema.sql",
    "test": "cross-env NODE_ENV=test jest --config ./test/jest.config.js --runInBand --forceExit",
    "test:unit": "cross-env NODE_ENV=test jest --config ./test/jest.config.js --runInBand --forceExit --testPathPattern=unit",
    "test:integration": "cross-env NODE_ENV=test jest --config ./test/jest.config.js --runInBand --forceExit --testPathPattern=integration",
    "test:e2e": "cross-env NODE_ENV=test jest --config ./test/jest.config.js --runInBand --forceExit --testPathPattern=e2e",
    "test:coverage": "cross-env NODE_ENV=test jest --config ./test/jest.config.js --runInBand --forceExit --coverage",
    "test:watch": "cross-env NODE_ENV=test jest --config ./test/jest.config.js --watch",
    "test:verbose": "cross-env NODE_ENV=test jest --config ./test/jest.config.js --runInBand --forceExit --verbose",
    "type-check": "tsc --noEmit"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.2.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "sharp": "^0.33.2",
    "stripe": "^14.14.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
